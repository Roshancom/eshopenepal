{
  "name": "eshopnepal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "pnpm run --parallel --filter @eshopnepal/backend --filter @eshopnepal/storefront --filter @eshopnepal/admin dev",
    "dev:backend": "pnpm --filter @eshopnepal/backend dev",
    "dev:storefront": "pnpm --filter @eshopnepal/storefront dev",
    "dev:admin": "pnpm --filter @eshopnepal/admin dev",
    "build": "pnpm -r build",
    "start": "NODE_ENV=production node dist/server.cjs",
    "clean": "rm -rf dist && pnpm -r exec rm -rf dist",
    "lint": "pnpm -r lint",
    "seed": "pnpm --filter @eshopnepal/backend seed"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "mysql2": "^3.22.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tsx": "^4.21.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "typescript": "~5.8.2"
  }
}
