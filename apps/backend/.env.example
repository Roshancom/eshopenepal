[TEMPLATE]
# Backend environment variables
# NOTE: PORT is intentionally NOT set here — it is controlled by the root .env
DATABASE_URL=mysql://root:root@localhost:3306/e_shop_nepal
JWT_SECRET=replace_with_a_64_char_random_secret_here

# ── Google OAuth (required for Google Sign-In) ────────────────────────
# Create at: https://console.cloud.google.com/ > Credentials > OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_client_id_here
# Comma-separated list of Google emails allowed to register as admin via Google
ADMIN_GOOGLE_EMAILS=admin@example.com
