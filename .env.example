# ── Server ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Separate Servers (dev:backend + dev:frontend) ─────────────────────
# When running `npm run dev:backend` (standalone API server):
BACKEND_PORT=3001
# When running `npm run dev:frontend` (standalone Vite dev server):
# The Vite dev server proxies /api requests here automatically.
BACKEND_URL=http://localhost:3001
# Set this if frontend runs on a different port, e.g. for CORS:
FRONTEND_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:port/dbname?ssl-mode=REQUIRED

# ── Authentication ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_secret_here

# ── CORS (restrict in production) ───────────────────────────────────────
ALLOWED_ORIGIN=https://your-domain.com

# ── Stripe (optional) ───────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ── Google OAuth (optional) ──────────────────────────────────────────────
# Create at: https://console.cloud.google.com/ > Credentials > OAuth 2.0 Client ID
# Backend uses: GOOGLE_CLIENT_ID (server-side token verification)
# Frontend uses: VITE_GOOGLE_CLIENT_ID (Google Sign-In button)
# Both should be the same value from your Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Google OAuth (optional) ──────────────────────────────────────────────
# Create at: https://console.cloud.google.com/ > Credentials > OAuth 2.0 Client ID
# Backend uses: GOOGLE_CLIENT_ID (server-side token verification)
# Frontend uses: VITE_GOOGLE_CLIENT_ID (Google Sign-In button)
# Both should be the same value from your Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
